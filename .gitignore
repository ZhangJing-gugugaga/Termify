# Dependencies
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
env/
.eggs/
*.egg-info/
dist/
build/
*.spec.bak
termify/build/
termify/dist/

# Temp upload / processing dirs (per-session, regenerated on demand)
uploads/
tmp/

# Demo output artifacts (regenerable via demo.py)
outputs/

# Logs
logs/
*.log

# Claude session / memory data (personal, not part of the product)
.claude/

# Environment / secrets — never commit real credentials
.env
.env.*
*.pem
*.key
.secrets/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Python REPL history
.python_history

# Playwright MCP screenshots + console logs
.playwright-mcp/
*.png

# throwaway dev scripts
_e2e.py
_fixline.py
tmp/_*.html

# browser-test scratch (salarycat copy + validation HTML)
static/test/

# throwaway one-off scripts
_*.py

# Allow documentation images
!images/
!images/*.png

# Tool config and session data (personal, not part of the product)
.mimocode/
.workbuddy/

# Test artifacts (temporary, regenerable)
test_*.json
test_*.py
static/geometric_preview.html
data/
